# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost/lance_db
# For development, you can use SQLite:
# DATABASE_URL=sqlite:///./lance.db

# Security Keys
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
SECRET_KEY=your-app-secret-key-change-this-in-production
APP_SECRET=your-app-secret-for-otp-change-this

# SMTP Configuration (for email sending)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
SMTP_FROM=no-reply@primustech.in
SMTP_TLS=1
SMTP_SSL=0

# Application Configuration
APP_BASE_URL=https://api.primustech.in
# For local development:
# APP_BASE_URL=http://localhost:8000

# OAuth Configuration (for social login)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
TWITTER_CLIENT_ID=your-twitter-client-id
TWITTER_CLIENT_SECRET=your-twitter-client-secret

# Payment Gateway Configuration
## Stripe
STRIPE_SECRET=your-stripe-secret-key
STRIPE_CURRENCY=usd
STRIPE_SUCCESS_URL=https://primustech.in/payment/success
STRIPE_CANCEL_URL=https://primustech.in/payment/cancel

## Razorpay
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_CURRENCY=INR
RAZORPAY_SUCCESS_URL=https://primustech.in/razorpay/success

# Firebase Configuration (if using Firebase)
FIREBASE_CREDENTIALS_JSON=/path/to/firebase-credentials.json

# Redis Configuration (for OTP and caching)
REDIS_URL=redis://127.0.0.1:6379/0

# OTP Configuration
OTP_TTL_SEC=300  # 5 minutes
RESEND_COOLDOWN_SEC=30
MAX_SENDS_PER_HOUR=5
MAX_ATTEMPTS=5

# Optional: Development Settings
# DEV_INBOX_DIR=./dev_emails  # For local email testing
# VERCEL=0  # Set to 1 if deploying on Vercel
